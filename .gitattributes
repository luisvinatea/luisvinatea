# Enforce LF line endings for all text files
* text=auto

# Ensure shell scripts have LF line endings
*.sh text eol=lf

# Ensure batch scripts have CRLF line endings
*.bat text eol=crlf

# Ensure CSV files have LF line endings
*.csv text eol=lf

# Ensure Jupyter Notebooks have LF line endings
*.ipynb text eol=lf

# Ensure .env files have LF line endings
*.env text eol=lf
